---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { parseChecklist, parseTables } from "../lib/mdtable";
import { statusClass, cleanStatus } from "../lib/status";
import { titleFor } from "../lib/sections";

const docs = await getCollection("docs");
const byId = new Map(docs.map((d) => [d.id, d]));

// Backlog
const backlog = byId.get("09_bauablauf/backlog");
const tasks = backlog ? parseChecklist(backlog.body ?? "") : [];
const offen = tasks.filter((t) => !t.done);
const erledigt = tasks.filter((t) => t.done);

// Offene Fragen – nach H2 gruppieren
const fragenDoc = byId.get("00_projekt/offene-fragen");
const fragenGruppen: { titel: string; fragen: string[] }[] = [];
if (fragenDoc) {
  let cur: { titel: string; fragen: string[] } | null = null;
  for (const line of (fragenDoc.body ?? "").split("\n")) {
    const h = line.match(/^##\s+(.*)$/);
    const li = line.match(/^[-*]\s+(.*)$/);
    if (h) {
      cur = { titel: h[1].trim(), fragen: [] };
      fragenGruppen.push(cur);
    } else if (li && cur) {
      cur.fragen.push(li[1].trim());
    }
  }
}
const fragenAnzahl = fragenGruppen.reduce((n, g) => n + g.fragen.length, 0);

// Entscheidungslog
const logDoc = byId.get("00_projekt/entscheidungslog");
const logTable = logDoc ? parseTables(logDoc.body ?? "")[0] : null;

// ADRs
const adrs = docs
  .filter((d) => d.id.startsWith("08_entscheidungen/"))
  .map((d) => ({
    id: d.id,
    titel: titleFor(d),
    status: (d.data.status as string | undefined) ?? "—",
  }))
  .sort((a, b) => a.id.localeCompare(b.id));
---

<Base title="Aufgaben & Fragen" current="aufgaben" crumb="Aufgaben & Fragen">
  <div class="page-head">
    <p class="eyebrow">Backlog · Offene Fragen · Entscheidungen</p>
    <h2>Aufgaben &amp; Fragen</h2>
    <p class="lead">{offen.length} offene Aufgaben · {fragenAnzahl} offene Fragen · {adrs.length} ADRs</p>
  </div>

  <div class="grid cols-2">
    <div class="card">
      <h3 class="card-h"><Icon name="list-checks" size={17} /> Backlog – offen <span class="count">{offen.length}</span></h3>
      {
        offen.length ? (
          <ul class="task-list" id="tasks-open">
            {offen.map((t) => (
              <li class="task-row">
                <label class="task-toggle">
                  <input type="checkbox" data-text={t.text} />
                  <span>{t.text}</span>
                </label>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Keine offenen Aufgaben.</p>
        )
      }
      <details style="margin-top:14px" hidden={erledigt.length === 0}>
        <summary class="muted" style="cursor:pointer; font-size:13px">
          <span id="done-count">{erledigt.length}</span> erledigt
        </summary>
        <ul class="task-list" style="margin-top:8px" id="tasks-done">
          {erledigt.map((t) => (
            <li class="task-row done">
              <label class="task-toggle">
                <input type="checkbox" checked data-text={t.text} />
                <span>{t.text}</span>
              </label>
            </li>
          ))}
        </ul>
      </details>
      <p class="muted" style="font-size:12px; margin-top:10px">
        Abhaken speichert direkt in der Akte (<code>09_bauablauf/backlog.md</code>).
      </p>
      <div class="btn-row"><a class="btn" href="/docs/09_bauablauf/backlog">Backlog öffnen <Icon name="arrow-right" size={15} /></a></div>
    </div>

    <div class="card">
      <h3 class="card-h"><Icon name="circle-help" size={17} /> Offene Fragen <span class="count">{fragenAnzahl}</span></h3>
      {
        fragenGruppen.map((g) => (
          <div style="margin-bottom:12px">
            <b style="font-size:13px; color:var(--accent)">{g.titel}</b>
            <ul style="margin:4px 0 0; padding-left:18px; font-size:14px; display:flex; flex-direction:column; gap:4px">
              {g.fragen.map((f) => <li>{f}</li>)}
            </ul>
          </div>
        ))
      }
      <div class="btn-row"><a class="btn" href="/docs/00_projekt/offene-fragen">Alle Fragen →</a></div>
    </div>
  </div>

  <h3 style="margin:30px 0 12px; display:flex; justify-content:space-between; align-items:center; gap:10px">
    <span class="card-h"><Icon name="circle-check" size={17} /> Entscheidungen (ADRs)</span>
    <a class="btn primary" style="font-size:13px" href="/admin/index.html#/collections/entscheidungen/new">+ Entscheidung</a>
  </h3>
  <div class="grid cols-3" style="margin-bottom:24px">
    {
      adrs.map((a) => (
        <a class="card link" href={`/docs/${a.id}`}>
          <h3 style="font-size:14px">{a.titel}</h3>
          <span class={`badge ${statusClass(a.status)}`}>{a.status}</span>
        </a>
      ))
    }
  </div>

  {
    logTable && (
      <>
        <h3 class="card-h" style="margin:24px 0 12px"><Icon name="clipboard-list" size={17} /> Entscheidungslog</h3>
        <div class="card" style="padding:0; overflow:hidden">
          <table class="prose" style="margin:0; width:100%">
            <thead>
              <tr>{logTable.headers.map((h) => <th>{h}</th>)}</tr>
            </thead>
            <tbody>
              {logTable.rows.map((row) => (
                <tr>
                  {row.map((c, i) => (
                    <td>{i === 2 ? <span class={`badge ${statusClass(c)}`}>{cleanStatus(c)}</span> : cleanStatus(c)}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )
  }

  <div id="save-toast" class="save-toast" hidden></div>
</Base>

<script>
  const WRITE_KEY = "portal:writekey";
  const toast = document.getElementById("save-toast")!;
  let toastTimer: number | undefined;

  function showToast(msg: string, ok: boolean) {
    toast.textContent = msg;
    toast.classList.toggle("err", !ok);
    toast.hidden = false;
    clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => (toast.hidden = true), 3500);
  }

  function getKey(): string | null {
    let key = localStorage.getItem(WRITE_KEY) || "";
    if (!key) {
      key = prompt("Speicher-Schlüssel (einmalig, wird im Browser gemerkt):") || "";
      if (!key) return null;
      localStorage.setItem(WRITE_KEY, key);
    }
    return key;
  }

  const openList = document.getElementById("tasks-open");
  const doneList = document.getElementById("tasks-done");
  const doneCount = document.getElementById("done-count");

  function refreshCounts() {
    if (doneCount && doneList) doneCount.textContent = String(doneList.children.length);
  }

  document.querySelectorAll<HTMLInputElement>('.task-toggle input[type="checkbox"]').forEach((box) => {
    box.addEventListener("change", async () => {
      const done = box.checked;
      const key = getKey();
      if (!key) {
        box.checked = !done;
        return;
      }
      box.disabled = true;
      try {
        const res = await fetch("/api/backlog/toggle", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text: box.dataset.text, done, key }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (res.status === 401) localStorage.removeItem(WRITE_KEY);
          throw new Error(data.error || `Fehler ${res.status}`);
        }
        // Zeile in die passende Liste verschieben
        const li = box.closest("li");
        if (li) {
          li.classList.toggle("done", done);
          (done ? doneList : openList)?.appendChild(li);
          refreshCounts();
        }
        showToast(done ? "Aufgabe erledigt ✓" : "Aufgabe wieder geöffnet", true);
      } catch (err) {
        box.checked = !done;
        showToast(`Speichern fehlgeschlagen: ${(err as Error).message}`, false);
      } finally {
        box.disabled = false;
      }
    });
  });
</script>

<style>
  .task-toggle {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    cursor: pointer;
  }
  .task-toggle input {
    margin-top: 3px;
    accent-color: var(--accent);
    cursor: pointer;
  }
  .task-row.done .task-toggle span {
    text-decoration: line-through;
    opacity: 0.7;
  }
  .save-toast {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #16a34a;
    color: #fff;
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 6px 20px rgb(0 0 0 / 0.25);
    z-index: 100;
  }
  .save-toast.err {
    background: #dc2626;
  }
</style>
