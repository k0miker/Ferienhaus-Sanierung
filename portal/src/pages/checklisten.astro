---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { parseChecklistDoc, checklistSlug } from "../lib/checklist";
import { titleFor, sectionFor } from "../lib/sections";

const docs = await getCollection("docs");
const checklisten = docs
  .filter((d) => d.data.typ === "checkliste")
  .map((d) => {
    const { sections, totalChecks } = parseChecklistDoc(d.body ?? "");
    return {
      slug: checklistSlug(d.id),
      title: titleFor(d),
      bereich: sectionFor(d.id),
      sectionCount: sections.length,
      totalChecks,
      icon: sections[0]?.icon ?? "clipboard-list",
    };
  })
  .sort((a, b) => a.bereich.order - b.bereich.order || a.title.localeCompare(b.title));

const gesamtChecks = checklisten.reduce((s, c) => s + c.totalChecks, 0);
---

<Base title="Checklisten" current="checklisten" crumb="Checklisten">
  <div class="page-head">
    <p class="eyebrow"><Icon name="square-check" size={13} /> Erfassung &amp; Begehung</p>
    <h2>Checklisten</h2>
    <p class="lead">
      {checklisten.length} Checklisten mit insgesamt {gesamtChecks} Prüfpunkten. Direkt im Browser
      abhaken und ausfüllen – mit „Speichern" wird die ausgefüllte Liste in die Projektakte
      geschrieben (versioniert in Git). Neue Checkliste? Markdown-Datei mit Frontmatter
      <code>typ: checkliste</code> anlegen.
    </p>
  </div>

  {checklisten.length === 0 ? (
    <p class="empty">
      Noch keine Checklisten. Lege eine Markdown-Datei mit <code>typ: checkliste</code> im
      Frontmatter an (z.&nbsp;B. in <code>01_bestand/</code>).
    </p>
  ) : (
    <div class="grid cols-2">
      {checklisten.map((c) => (
        <a class="card link cl-card" href={`/checklisten/${c.slug}`}>
          <div class="cl-card-top">
            <span class="cl-card-ico"><Icon name={c.icon} size={20} /></span>
            <span class="badge" data-cl-badge={c.slug}>0/{c.totalChecks}</span>
          </div>
          <h3>{c.title}</h3>
          <div class="cl-bar"><div class="cl-bar-fill" data-cl-fill={c.slug} style="width:0%"></div></div>
          <span class="meta">
            <Icon name={c.bereich.icon} size={13} /> {c.bereich.label} · {c.sectionCount} Abschnitte · {c.totalChecks} Prüfpunkte
          </span>
        </a>
      ))}
    </div>
  )}

  <script>
    // Fortschritt je Karte aus localStorage (gleiche Keys wie Detailseite).
    document.querySelectorAll<HTMLElement>("[data-cl-fill]").forEach((fill) => {
      const slug = fill.dataset.clFill!;
      let state: Record<string, unknown> = {};
      try {
        state = JSON.parse(localStorage.getItem("checklist:" + slug + ":v1") || "{}");
      } catch {}
      const badge = document.querySelector<HTMLElement>(`[data-cl-badge="${slug}"]`);
      const total = Number(badge?.textContent?.split("/")[1] ?? 0);
      const done = Object.values(state).filter((v) => v === true).length;
      const capped = Math.min(done, total);
      fill.style.width = (total ? Math.round((capped / total) * 100) : 0) + "%";
      if (badge) {
        badge.textContent = `${capped}/${total}`;
        badge.className = "badge " + (total && capped >= total ? "ok" : capped > 0 ? "info" : "");
      }
    });
  </script>
</Base>

<style>
  .cl-card { display: flex; flex-direction: column; gap: 10px; }
  .cl-card-top { display: flex; align-items: center; justify-content: space-between; }
  .cl-card-ico {
    width: 40px; height: 40px; border-radius: 10px; display: grid; place-items: center;
    background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent);
  }
  .cl-card h3 { margin: 0; }
  .cl-card .meta { display: flex; align-items: center; gap: 6px; }
  .cl-bar { height: 8px; border-radius: 6px; background: var(--panel-2); overflow: hidden; }
  .cl-bar-fill { height: 100%; background: var(--accent); transition: width 0.25s ease; }
</style>
