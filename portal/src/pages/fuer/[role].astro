---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import { ROLES, ROLE_BY_KEY } from "../../lib/roles";
import { parseChecklist, parseTables } from "../../lib/mdtable";
import { parseChecklistDoc } from "../../lib/checklist";

export async function getStaticPaths() {
  return ROLES.map((r) => ({ params: { role: r.key }, props: { role: r } }));
}

const { role } = Astro.props;
const docs = await getCollection("docs");
const positionen = await getCollection("kosten");
const byId = new Map(docs.map((d) => [d.id.toLowerCase(), d]));

// ---- Live-Kennzahlen ----
const backlog = byId.get("09_bauablauf/backlog");
const tasks = backlog ? parseChecklist(backlog.body ?? "") : [];
const offeneTasks = tasks.filter((t) => !t.done).length;

const fragenDoc = byId.get("00_projekt/offene-fragen");
const fragenAnzahl = (fragenDoc?.body ?? "").split("\n").filter((l) => /^[-*]\s+/.test(l)).length;

const adrs = docs.filter((d) => d.id.startsWith("08_entscheidungen/")).length;

const checklisten = docs.filter((d) => d.data.typ === "checkliste");
const checklistenChecks = checklisten.reduce((s, d) => s + parseChecklistDoc(d.body ?? "").totalChecks, 0);

const istFoerderung = (g: string) => g.startsWith("Förderung");
const geplant = positionen.reduce((s, p) => (istFoerderung(p.data.gruppe) ? s : s + p.data.betrag), 0);
const euro = (n: number) => n.toLocaleString("de-DE", { style: "currency", currency: "EUR", maximumFractionDigits: 0 });

// nächster Termin: erste Datenzeile der ersten Tabelle im Bauzeitenplan
const bzp = byId.get("09_bauablauf/bauzeitenplan");
const bzpTable = bzp ? parseTables(bzp.body ?? "")[0] : null;
const naechster = bzpTable?.rows?.[0] ? bzpTable.rows[0].slice(0, 2).filter(Boolean).join(" · ") : null;

const STAT = {
  tasks: { label: "Offene Aufgaben", value: String(offeneTasks), icon: "list-checks", href: "/aufgaben" },
  fragen: { label: "Offene Fragen", value: String(fragenAnzahl), icon: "circle-help", href: "/aufgaben" },
  adrs: { label: "Entscheidungen", value: String(adrs), icon: "circle-check", href: "/aufgaben" },
  checklisten: { label: "Prüfpunkte", value: String(checklistenChecks), icon: "square-check", href: "/checklisten" },
  budget: { label: "Geplant", value: geplant ? euro(geplant) : "—", icon: "euro", href: "/kosten" },
  "naechster-termin": { label: "Nächster Schritt", value: naechster ?? "—", icon: "calendar-days", href: "/zeitplan" },
} as const;

const stats = role.stats.map((k) => STAT[k]).filter(Boolean);
const others = ROLES.filter((r) => r.key !== role.key);
---

<Base title={`Für ${role.label}`} current={`rolle-${role.key}`} crumb={`Für ${role.label}`}>
  <div class="page-head">
    <p class="eyebrow"><Icon name={role.icon} size={13} /> Rollen-Sicht</p>
    <h2>Für die {role.label}</h2>
    <p class="lead">{role.tagline}</p>
  </div>

  {stats.length > 0 && (
    <div class="grid cols-4" style="margin-bottom:8px">
      {stats.map((s) => (
        <a class="card stat link" href={s.href}>
          <span class="label"><Icon name={s.icon} size={13} /> {s.label}</span>
          <span class="value stat-value">{s.value}</span>
        </a>
      ))}
    </div>
  )}

  <h2 class="section-head">Werkzeuge</h2>
  <div class="grid cols-2">
    {role.werkzeuge.map((l) => (
      <a class="card link tool-card" href={l.href}>
        <span class="tool-ico"><Icon name={l.icon} size={20} /></span>
        <span class="tool-body">
          <b>{l.label}</b>
          {l.desc && <span class="meta">{l.desc}</span>}
        </span>
        <Icon name="arrow-right" size={16} class="tool-arrow" />
      </a>
    ))}
  </div>

  <h2 class="section-head">Relevante Dokumente</h2>
  <div class="card doc-list">
    {role.dokumente.map((l) => (
      <a class="doc-row" href={l.href}>
        <Icon name={l.icon} size={16} />
        <span>{l.label}</span>
        <Icon name="arrow-right" size={14} class="doc-arrow" />
      </a>
    ))}
  </div>

  <h2 class="section-head">Andere Rollen</h2>
  <div class="role-switch">
    {others.map((r) => (
      <a class="chip" href={`/fuer/${r.key}`}><Icon name={r.icon} size={14} /> {r.label}</a>
    ))}
    <a class="chip" href="/"><Icon name="home" size={14} /> Start</a>
  </div>
</Base>

<style>
  .stat-value { font-size: 18px; line-height: 1.3; }
  .tool-card { display: flex; align-items: center; gap: 14px; }
  .tool-ico { width: 44px; height: 44px; flex: none; border-radius: 11px; display: grid; place-items: center; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); }
  .tool-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .tool-body b { color: var(--heading); }
  .tool-arrow { margin-left: auto; color: var(--muted); flex: none; }

  .doc-list { padding: 6px; }
  .doc-row { display: flex; align-items: center; gap: 11px; padding: 11px 12px; border-radius: var(--radius-sm); color: var(--text); font-size: 14.5px; }
  .doc-row:hover { background: var(--panel-2); text-decoration: none; }
  .doc-row > svg:first-child { color: var(--accent); flex: none; }
  .doc-arrow { margin-left: auto; color: var(--muted); }

  .role-switch { display: flex; flex-wrap: wrap; gap: 10px; }
  .chip { display: inline-flex; align-items: center; gap: 7px; padding: 8px 14px; border-radius: 20px; border: 1px solid var(--border); background: var(--panel); color: var(--text); font-size: 13px; font-weight: 600; }
  .chip:hover { border-color: var(--accent); color: var(--accent); text-decoration: none; }
</style>
