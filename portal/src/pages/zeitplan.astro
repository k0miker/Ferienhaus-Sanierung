---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { tableUnderHeading } from "../lib/mdtable";
import { statusClass, cleanStatus } from "../lib/status";

const docs = await getCollection("docs");
const byId = new Map(docs.map((d) => [d.id.toLowerCase(), d]));
const status = byId.get("projektstatus");
const body = status?.body ?? "";

const schritte = [
  {
    nr: 1,
    titel: "Unterlagen sammeln und sichern",
    phase: "Vorbereitung",
    status: "IN ARBEIT",
    details: "Energieausweis, Grundriss, Kaufvertrag, PV-Unterlagen digital ablegen",
    abhaengig: "—",
  },
  {
    nr: 2,
    titel: "Baurechtliche Nutzung und Förderfähigkeit klären",
    phase: "Vorbereitung",
    status: "OFFEN",
    details: "Stadt/Bauamt: dauerhafte Wohnnutzung? Energieberater: Förderfähigkeit?",
    abhaengig: "—",
  },
  {
    nr: 3,
    titel: "Bestandsaufmaß und Fotodokumentation",
    phase: "Vorbereitung",
    status: "OFFEN",
    details: "Raummaße, Fensterinventar, PV-Typenschilder, Elektro → Checklisten nutzen",
    abhaengig: "—",
  },
  {
    nr: 4,
    titel: "Statik Wanddurchbruch klären",
    phase: "Planung",
    status: "OFFEN",
    details: "Tragwerksplaner beauftragen – ist die Wand tragend/aussteifend?",
    abhaengig: "3",
  },
  {
    nr: 5,
    titel: "Dach, Feuchte, Holz, Außenwand untersuchen",
    phase: "Planung",
    status: "OFFEN",
    details: "Endoskopie Außenwand, Dachboden-Inspektion, Feuchtemesung",
    abhaengig: "3",
  },
  {
    nr: 6,
    titel: "Elektro- und Zähleranlage prüfen",
    phase: "Planung",
    status: "OFFEN",
    details: "Bestandsprüfung, Reserven für WP/DLE, FI-Schutz, Leitungsquerschnitte",
    abhaengig: "3",
  },
  {
    nr: 7,
    titel: "Zielzustand festlegen (Hülle, Fenster, Lüftung)",
    phase: "Planung",
    status: "OFFEN",
    details: "Dämm-Variante, Fenstertyp, Lüftungskonzept auf Basis der Untersuchungen",
    abhaengig: "2, 4, 5",
  },
  {
    nr: 8,
    titel: "Angebote Hülle und Fenster einholen",
    phase: "Angebote",
    status: "OFFEN",
    details: "2–3 Vergleichsangebote je Gewerk, Fensterliste als Grundlage",
    abhaengig: "7",
  },
  {
    nr: 9,
    titel: "Sanierte U-Werte und Heizlast ermitteln",
    phase: "Planung",
    status: "OFFEN",
    details: "Raumweise Heizlast für den geplanten Endzustand berechnen",
    abhaengig: "7, 8",
  },
  {
    nr: 10,
    titel: "Heizsystem vergleichen und entscheiden",
    phase: "Entscheidung",
    status: "OFFEN",
    details: "Split-Klima vs. LW-WP+FBH – Kosten, Förderung, Komfort bewerten",
    abhaengig: "9",
  },
  {
    nr: 11,
    titel: "Warmwasserlösung festlegen",
    phase: "Entscheidung",
    status: "OFFEN",
    details: "Durchlauferhitzer vs. Brauchwasser-WP – abhängig von Heizsystem",
    abhaengig: "10",
  },
  {
    nr: 12,
    titel: "Bauablauf, Kostenplan und Reserve finalisieren",
    phase: "Entscheidung",
    status: "OFFEN",
    details: "Reihenfolge der Gewerke, Gesamtbudget, Reserveplanung",
    abhaengig: "8, 10, 11",
  },
  {
    nr: 13,
    titel: "Förderanträge stellen",
    phase: "Förderung",
    status: "OFFEN",
    details: "Vor bindender Beauftragung! iSFP, BEG-Einzelmaßnahmen, ggf. KfW",
    abhaengig: "2, 12",
  },
  {
    nr: 14,
    titel: "Ausführung mit Dokumentation begleiten",
    phase: "Ausführung",
    status: "OFFEN",
    details: "Foto-, Rechnungs- und Abnahmedokumentation laufend führen",
    abhaengig: "13",
  },
];

const phasen = [...new Set(schritte.map((s) => s.phase))];
const phasenFarbe: Record<string, string> = {
  Vorbereitung: "#5aa9e6",
  Planung: "#7ed0a3",
  Angebote: "#f5c451",
  Entscheidung: "#e09cf0",
  Förderung: "#f5c451",
  Ausführung: "#ef6a6a",
};

const statusFarbe = (s: string) => {
  if (s === "IN ARBEIT") return "info";
  if (s === "ERLEDIGT") return "ok";
  return "warn";
};
---

<Base title="Zeitplan" current="zeitplan" crumb="Zeitplan">
  <div class="page-head">
    <p class="eyebrow">Sanierungsreihenfolge</p>
    <h2>Zeitplan</h2>
    <p class="lead">
      14 Schritte von der Bestandsaufnahme bis zur Ausführung.
      Abhängigkeiten zeigen, welche Schritte aufeinander aufbauen.
    </p>
  </div>

  <!-- Phasen-Legende -->
  <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:22px">
    {phasen.map((p) => (
      <span style={`display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:600; padding:4px 12px; border-radius:20px; background:${phasenFarbe[p] ?? "var(--panel)"}22; color:${phasenFarbe[p] ?? "var(--text)"}; border:1px solid ${phasenFarbe[p] ?? "var(--border)"}44`}>
        <span style={`width:8px; height:8px; border-radius:50%; background:${phasenFarbe[p] ?? "var(--muted)"}`}></span>
        {p}
      </span>
    ))}
  </div>

  <!-- Timeline -->
  <div class="timeline">
    {schritte.map((s, i) => (
      <div class="tl-item" style={`--phase-color:${phasenFarbe[s.phase] ?? "var(--muted)"}`}>
        <div class="tl-marker">
          <span class="tl-dot"></span>
          {i < schritte.length - 1 && <span class="tl-line"></span>}
        </div>
        <div class="card" style="flex:1">
          <div style="display:flex; justify-content:space-between; align-items:start; gap:10px; flex-wrap:wrap">
            <h3 style="margin:0; font-size:15px">
              <span class="muted" style="font-size:13px; margin-right:6px">#{s.nr}</span>
              {s.titel}
            </h3>
            <div style="display:flex; gap:6px; flex-shrink:0">
              <span class={`badge ${statusFarbe(s.status)}`}>{s.status}</span>
              <span style={`font-size:11px; padding:3px 9px; border-radius:20px; background:${phasenFarbe[s.phase]}22; color:${phasenFarbe[s.phase]}; border:1px solid ${phasenFarbe[s.phase]}44; font-weight:600`}>
                {s.phase}
              </span>
            </div>
          </div>
          <p class="muted" style="margin:6px 0 0; font-size:14px">{s.details}</p>
          {s.abhaengig !== "—" && (
            <p style="margin:6px 0 0; font-size:12px; color:var(--accent)">
              Abhängig von: Schritt {s.abhaengig}
            </p>
          )}
        </div>
      </div>
    ))}
  </div>

  <div class="btn-row" style="margin-top:24px">
    <a class="btn" href="/docs/projektstatus">Voller Projektstatus</a>
    <a class="btn" href="/aufgaben">Aufgaben & Fragen</a>
    <a class="btn" href="/docs/09_bauablauf/bauzeitenplan">Bauzeitenplan</a>
  </div>
</Base>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .tl-item {
    display: flex;
    gap: 16px;
    align-items: stretch;
  }
  .tl-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 24px;
    flex-shrink: 0;
    padding-top: 20px;
  }
  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--phase-color);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 2px var(--phase-color);
    flex-shrink: 0;
    z-index: 1;
  }
  .tl-line {
    width: 2px;
    flex: 1;
    background: var(--border);
    margin: 4px 0;
  }
  .tl-item .card {
    margin-bottom: 12px;
  }
</style>
