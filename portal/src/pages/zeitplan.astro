---
import fs from "node:fs";
import path from "node:path";
import Base from "../layouts/Base.astro";

// Schritte kommen aus der Akte (09_bauablauf/zeitplan.json) und werden dort
// über /api/zeitplan/save gepflegt (Status-Dropdown unten).
const zeitplanPath = path.resolve(process.cwd(), "..", "09_bauablauf", "zeitplan.json");
const zeitplan = JSON.parse(fs.readFileSync(zeitplanPath, "utf8")) as {
  schritte: {
    nr: number;
    titel: string;
    phase: string;
    status: string;
    details: string;
    abhaengig: string;
  }[];
};
const schritte = zeitplan.schritte;
const erledigt = schritte.filter((s) => s.status === "ERLEDIGT").length;

const phasen = [...new Set(schritte.map((s) => s.phase))];
// Mitteltöne: lesbar auf hellem und dunklem Hintergrund (Phasen-Chips)
const phasenFarbe: Record<string, string> = {
  Vorbereitung: "#2563eb",
  Planung: "#0891b2",
  Angebote: "#b45309",
  Entscheidung: "#7c3aed",
  Förderung: "#ca8a04",
  Ausführung: "#dc2626",
};

const STATUS_OPTIONEN = ["OFFEN", "IN ARBEIT", "ERLEDIGT"];
---

<Base title="Zeitplan" current="zeitplan" crumb="Zeitplan">
  <div class="page-head">
    <p class="eyebrow">Sanierungsreihenfolge</p>
    <h2>Zeitplan</h2>
    <p class="lead">
      {schritte.length} Schritte von der Bestandsaufnahme bis zur Ausführung
      · {erledigt} erledigt. Status lässt sich direkt hier ändern.
    </p>
  </div>

  <!-- Phasen-Legende -->
  <div style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:22px">
    {phasen.map((p) => (
      <span style={`display:inline-flex; align-items:center; gap:6px; font-size:13px; font-weight:600; padding:4px 12px; border-radius:20px; background:${phasenFarbe[p] ?? "var(--panel)"}22; color:${phasenFarbe[p] ?? "var(--text)"}; border:1px solid ${phasenFarbe[p] ?? "var(--border)"}44`}>
        <span style={`width:8px; height:8px; border-radius:50%; background:${phasenFarbe[p] ?? "var(--muted)"}`}></span>
        {p}
      </span>
    ))}
  </div>

  <!-- Timeline -->
  <div class="timeline">
    {schritte.map((s, i) => (
      <div class="tl-item" style={`--phase-color:${phasenFarbe[s.phase] ?? "var(--muted)"}`}>
        <div class="tl-marker">
          <span class="tl-dot"></span>
          {i < schritte.length - 1 && <span class="tl-line"></span>}
        </div>
        <div class={`card${s.status === "ERLEDIGT" ? " step-done" : ""}`} style="flex:1">
          <div style="display:flex; justify-content:space-between; align-items:start; gap:10px; flex-wrap:wrap">
            <h3 style="margin:0; font-size:15px">
              <span class="muted" style="font-size:13px; margin-right:6px">#{s.nr}</span>
              {s.titel}
            </h3>
            <div style="display:flex; gap:6px; flex-shrink:0; align-items:center">
              <select class="status-select" data-nr={s.nr} data-prev={s.status} aria-label={`Status von Schritt ${s.nr}`}>
                {STATUS_OPTIONEN.map((o) => (
                  <option value={o} selected={o === s.status}>{o}</option>
                ))}
              </select>
              <span style={`font-size:11px; padding:3px 9px; border-radius:20px; background:${phasenFarbe[s.phase]}22; color:${phasenFarbe[s.phase]}; border:1px solid ${phasenFarbe[s.phase]}44; font-weight:600`}>
                {s.phase}
              </span>
            </div>
          </div>
          <p class="muted" style="margin:6px 0 0; font-size:14px">{s.details}</p>
          {s.abhaengig !== "—" && (
            <p style="margin:6px 0 0; font-size:12px; color:var(--accent)">
              Abhängig von: Schritt {s.abhaengig}
            </p>
          )}
        </div>
      </div>
    ))}
  </div>

  <p class="muted" style="font-size:12px; margin-top:14px">
    Änderungen werden in der Projektakte gespeichert (<code>09_bauablauf/zeitplan.json</code>).
    Online dauert es nach dem Speichern ca. 1–2 Minuten, bis die Seite neu gebaut ist.
  </p>

  <div class="btn-row" style="margin-top:12px">
    <a class="btn" href="/docs/projektstatus">Voller Projektstatus</a>
    <a class="btn" href="/aufgaben">Aufgaben & Fragen</a>
    <a class="btn" href="/docs/09_bauablauf/bauzeitenplan">Bauzeitenplan</a>
  </div>

  <div id="save-toast" class="save-toast" hidden></div>
</Base>

<script>
  const WRITE_KEY = "portal:writekey";
  const toast = document.getElementById("save-toast")!;
  let toastTimer: number | undefined;

  function showToast(msg: string, ok: boolean) {
    toast.textContent = msg;
    toast.classList.toggle("err", !ok);
    toast.hidden = false;
    clearTimeout(toastTimer);
    toastTimer = window.setTimeout(() => (toast.hidden = true), 3500);
  }

  function getKey(): string | null {
    let key = localStorage.getItem(WRITE_KEY) || "";
    if (!key) {
      key = prompt("Speicher-Schlüssel (einmalig, wird im Browser gemerkt):") || "";
      if (!key) return null;
      localStorage.setItem(WRITE_KEY, key);
    }
    return key;
  }

  function styleSelect(sel: HTMLSelectElement) {
    sel.dataset.status = sel.value;
  }

  document.querySelectorAll<HTMLSelectElement>(".status-select").forEach((sel) => {
    styleSelect(sel);
    sel.addEventListener("change", async () => {
      const prev = sel.dataset.prev || "OFFEN";
      const key = getKey();
      if (!key) {
        sel.value = prev;
        return;
      }
      sel.disabled = true;
      try {
        const res = await fetch("/api/zeitplan/save", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ nr: Number(sel.dataset.nr), status: sel.value, key }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) {
          if (res.status === 401) localStorage.removeItem(WRITE_KEY);
          throw new Error(data.error || `Fehler ${res.status}`);
        }
        sel.dataset.prev = sel.value;
        styleSelect(sel);
        sel.closest(".card")?.classList.toggle("step-done", sel.value === "ERLEDIGT");
        showToast(`Schritt ${sel.dataset.nr}: ${sel.value} gespeichert`, true);
      } catch (err) {
        sel.value = prev;
        styleSelect(sel);
        showToast(`Speichern fehlgeschlagen: ${(err as Error).message}`, false);
      } finally {
        sel.disabled = false;
      }
    });
  });
</script>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .tl-item {
    display: flex;
    gap: 16px;
    align-items: stretch;
  }
  .tl-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 24px;
    flex-shrink: 0;
    padding-top: 20px;
  }
  .tl-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--phase-color);
    border: 3px solid var(--bg);
    box-shadow: 0 0 0 2px var(--phase-color);
    flex-shrink: 0;
    z-index: 1;
  }
  .tl-line {
    width: 2px;
    flex: 1;
    background: var(--border);
    margin: 4px 0;
  }
  .tl-item .card {
    margin-bottom: 12px;
  }
  .tl-item .card.step-done {
    opacity: 0.72;
  }
  .status-select {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 6px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--panel);
    color: var(--text);
    cursor: pointer;
  }
  .status-select[data-status="ERLEDIGT"] {
    background: #16a34a22;
    color: #16a34a;
    border-color: #16a34a55;
  }
  .status-select[data-status="IN ARBEIT"] {
    background: #2563eb22;
    color: #2563eb;
    border-color: #2563eb55;
  }
  .status-select[data-status="OFFEN"] {
    background: #d9770622;
    color: #d97706;
    border-color: #d9770655;
  }
  .save-toast {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #16a34a;
    color: #fff;
    padding: 10px 16px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 6px 20px rgb(0 0 0 / 0.25);
    z-index: 100;
  }
  .save-toast.err {
    background: #dc2626;
  }
</style>
