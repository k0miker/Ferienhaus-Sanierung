---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";

const beispiele = [
  "Welche Entscheidungen sind schon getroffen – und warum?",
  "Was muss vor dem Fenstertausch noch geklärt werden?",
  "Fasse den Energiezustand des Hauses zusammen.",
  "Welche Widersprüche gibt es aktuell in der Akte?",
];
---

<Base title="KI-Assistent" current="assistent" crumb="KI-Assistent">
  <div class="page-head">
    <p class="eyebrow"><Icon name="bot" size={13} /> Fragen an die Projektakte</p>
    <h2>KI-Assistent</h2>
    <p class="lead">
      Beantwortet Fragen auf Basis der kompletten Akte – mit Quellenangabe.
      Offenes und Widersprüchliches wird als solches benannt, nichts erfunden.
    </p>
  </div>

  <div class="chat-wrap card">
    <div class="chat-log" id="chat-log">
      <div class="chat-empty" id="chat-empty">
        <Icon name="bot" size={30} />
        <p>Stell eine Frage – zum Beispiel:</p>
        <div class="chips">
          {beispiele.map((b) => <button type="button" class="chip-q">{b}</button>)}
        </div>
      </div>
    </div>

    <form class="chat-input" id="chat-form">
      <textarea id="chat-text" rows="2" placeholder="Frage zur Sanierung, zu Maßen, Kosten, Entscheidungen …" required></textarea>
      <div class="chat-input-row">
        <button type="button" class="btn" id="chat-reset" title="Verlauf löschen">
          <Icon name="trash" size={14} /> Neu
        </button>
        <button type="submit" class="btn primary" id="chat-send">
          <Icon name="arrow-right" size={15} /> Fragen
        </button>
      </div>
    </form>
  </div>

  <p class="muted" style="font-size:12px; margin-top:14px; display:flex; align-items:center; gap:6px">
    <Icon name="circle-help" size={13} /> Antworten sind KI-generiert und ersetzen keine
    fachliche Prüfung (Statik, Elektro, Feuchte, Förderung). Bei Zweifel Quelle in der Akte prüfen.
  </p>
</Base>

<script>
  const STORE = "portal:chat";
  const log = document.getElementById("chat-log")!;
  const empty = document.getElementById("chat-empty")!;
  const form = document.getElementById("chat-form") as HTMLFormElement;
  const text = document.getElementById("chat-text") as HTMLTextAreaElement;
  const send = document.getElementById("chat-send") as HTMLButtonElement;
  const reset = document.getElementById("chat-reset") as HTMLButtonElement;

  interface Turn {
    role: "user" | "assistant";
    content: string;
  }
  let turns: Turn[] = [];
  try {
    turns = JSON.parse(sessionStorage.getItem(STORE) || "[]");
  } catch {
    turns = [];
  }

  const esc = (s: string) =>
    s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

  /** Sehr kleine Markdown-Teilmenge: fett, Code, Listen, Absätze. */
  function render(md: string): string {
    const inline = (s: string) =>
      esc(s)
        .replace(/\*\*([^*]+)\*\*/g, "<b>$1</b>")
        .replace(/`([^`]+)`/g, "<code>$1</code>")
        .replace(/_\(([^)]+)\)_/g, "<em>($1)</em>");
    const blocks = md.trim().split(/\n{2,}/);
    return blocks
      .map((b) => {
        const lines = b.split("\n");
        if (lines.every((l) => /^\s*[-*•]\s+/.test(l) || !l.trim())) {
          const items = lines
            .filter((l) => l.trim())
            .map((l) => `<li>${inline(l.replace(/^\s*[-*•]\s+/, ""))}</li>`)
            .join("");
          return `<ul>${items}</ul>`;
        }
        if (/^#{1,4}\s+/.test(lines[0])) {
          return `<p><b>${inline(lines[0].replace(/^#{1,4}\s+/, ""))}</b></p>`;
        }
        return `<p>${lines.map(inline).join("<br>")}</p>`;
      })
      .join("");
  }

  function addBubble(role: "user" | "assistant", content: string): HTMLDivElement {
    empty.hidden = true;
    const div = document.createElement("div");
    div.className = "msg " + role;
    div.innerHTML = role === "user" ? `<p>${esc(content)}</p>` : render(content);
    log.appendChild(div);
    log.scrollTop = log.scrollHeight;
    return div;
  }

  function save() {
    try {
      sessionStorage.setItem(STORE, JSON.stringify(turns.slice(-24)));
    } catch {
      /* voll/gesperrt – egal */
    }
  }

  // Verlauf wiederherstellen
  for (const t of turns) addBubble(t.role, t.content);

  async function ask(frage: string) {
    if (!frage.trim() || send.disabled) return;
    send.disabled = true;
    text.value = "";
    turns.push({ role: "user", content: frage });
    addBubble("user", frage);
    const bubble = addBubble("assistant", "");
    bubble.classList.add("pending");
    bubble.innerHTML = "<p><em>denkt nach…</em></p>";

    let answer = "";
    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages: turns }),
      });
      if (!res.ok || !res.body) {
        const data = await res.json().catch(() => ({}));
        throw new Error((data as { error?: string }).error || `HTTP ${res.status}`);
      }
      const reader = res.body.getReader();
      const dec = new TextDecoder();
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        answer += dec.decode(value, { stream: true });
        bubble.classList.remove("pending");
        bubble.innerHTML = render(answer);
        log.scrollTop = log.scrollHeight;
      }
      turns.push({ role: "assistant", content: answer });
      save();
    } catch (err) {
      turns.pop(); // Frage aus Verlauf nehmen, damit erneut gefragt werden kann
      bubble.classList.remove("pending");
      bubble.innerHTML = `<p><em>Fehler: ${esc((err as Error).message)}</em></p>`;
    } finally {
      send.disabled = false;
      text.focus();
    }
  }

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    ask(text.value);
  });
  text.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      ask(text.value);
    }
  });
  reset.addEventListener("click", () => {
    turns = [];
    save();
    log.querySelectorAll(".msg").forEach((m) => m.remove());
    empty.hidden = false;
    text.focus();
  });
  document.querySelectorAll<HTMLButtonElement>(".chip-q").forEach((c) =>
    c.addEventListener("click", () => ask(c.textContent || "")),
  );
</script>

<style>
  .chat-wrap { display: flex; flex-direction: column; padding: 0; overflow: hidden; }
  .chat-log {
    min-height: 320px; max-height: min(58vh, 620px); overflow-y: auto;
    padding: 18px; display: flex; flex-direction: column; gap: 12px;
  }
  .chat-empty {
    margin: auto; text-align: center; color: var(--muted);
    display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 26px 10px;
  }
  .chat-empty p { margin: 0; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .chip-q {
    border: 1px solid var(--border); background: var(--panel-2); color: var(--text);
    border-radius: 18px; padding: 7px 13px; font-size: 12.5px; cursor: pointer; font: inherit;
  }
  .chip-q:hover { border-color: var(--accent); color: var(--accent); }
  .msg { max-width: 85%; padding: 10px 14px; border-radius: 14px; font-size: 14px; line-height: 1.55; }
  .msg :global(p) { margin: 0 0 8px; }
  .msg :global(p:last-child) { margin-bottom: 0; }
  .msg :global(ul) { margin: 0 0 8px; padding-left: 20px; }
  .msg :global(code) { background: var(--panel-2); padding: 1px 5px; border-radius: 5px; font-size: 12.5px; }
  .msg.user {
    align-self: flex-end; background: color-mix(in srgb, var(--accent) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
  }
  .msg.assistant { align-self: flex-start; background: var(--panel-2); border: 1px solid var(--border); }
  .msg.pending :global(em) { color: var(--muted); }
  .chat-input { border-top: 1px solid var(--border); padding: 12px 14px; display: flex; flex-direction: column; gap: 10px; }
  .chat-input textarea {
    width: 100%; resize: vertical; min-height: 44px; padding: 10px 12px; box-sizing: border-box;
    border-radius: var(--radius-sm); border: 1px solid var(--border);
    background: var(--panel-2); color: var(--text); font: inherit;
  }
  .chat-input-row { display: flex; justify-content: space-between; gap: 10px; }
</style>
