---
import Base from "../layouts/Base.astro";
import { listMedia } from "../lib/media";

const media = listMedia();
const plaene = media.filter((m) => m.kind === "plan");
const bilder = media.filter((m) => m.kind === "bild");
const pdfs = media.filter((m) => m.kind === "pdf");

const groups = [
  { title: "🗺️ Pläne & Grundrisse", items: plaene },
  { title: "🖼️ Fotos & Bilder", items: bilder },
  { title: "📄 PDF-Originale", items: pdfs },
].filter((g) => g.items.length > 0);
---

<Base title="Pläne & Medien" current="medien" crumb="Pläne & Medien">
  <div class="page-head">
    <p class="eyebrow">Originalunterlagen</p>
    <h2>🖼️ Pläne &amp; Medien</h2>
    <p class="lead">{media.length} Dateien. Originale bleiben unverändert (AGENTS.md §2).</p>
  </div>

  <div class="card link" style="margin-bottom:26px; display:flex; align-items:center; gap:16px; border-color:var(--accent)">
    <div style="font-size:34px">📐</div>
    <div style="flex:1">
      <h3 style="margin:0">Grundriss-Planung (RemPlanner)</h3>
      <span class="meta">Interaktive Raum- und Maßplanung – Quelle der abgelesenen Flächen.</span>
    </div>
    <a class="btn primary" href="https://remplanner.com/planner/" target="_blank" rel="noopener">Planer öffnen ↗</a>
  </div>

  {
    groups.map((g) => (
      <section style="margin-bottom:30px">
        <h3 style="margin:0 0 12px">{g.title} <span class="count">{g.items.length}</span></h3>
        <div class="grid cols-3">
          {g.items.map((m) =>
            m.ext === ".pdf" ? (
              <a class="card link" href={m.url} target="_blank" rel="noopener">
                <div style="font-size:34px">📄</div>
                <h3 style="font-size:14px; word-break:break-word">{m.name}</h3>
                <span class="meta">{m.dir}</span>
              </a>
            ) : (
              <a class="card link" href={m.url} target="_blank" rel="noopener" style="padding:0; overflow:hidden">
                <div style="aspect-ratio:4/3; background:#0c1117; display:grid; place-items:center">
                  <img src={m.url} alt={m.name} loading="lazy"
                    style="max-width:100%; max-height:100%; object-fit:contain; border:none; border-radius:0" />
                </div>
                <div style="padding:12px">
                  <h3 style="font-size:13px; margin:0; word-break:break-word">{m.name}</h3>
                  <span class="meta">{m.dir}</span>
                </div>
              </a>
            ),
          )}
        </div>
      </section>
    ))
  }

  {media.length === 0 && <p class="empty">Keine Medien gefunden.</p>}
</Base>
