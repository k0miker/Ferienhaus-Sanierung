---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { tableUnderHeading, ampelOf } from "../lib/mdtable";
import { ROLES } from "../lib/roles";

// Kompakter Projektstand-Teaser aus PROJEKTSTATUS.md
const docs = await getCollection("docs");
const byId = new Map(docs.map((d) => [d.id.toLowerCase(), d]));
const body = byId.get("projektstatus")?.body ?? "";
const stand = body.match(/\*\*Stand:\*\*\s*([0-9-]+)/)?.[1];

const ampel = tableUnderHeading(body, /Projektampel/i);
const counts = { rot: 0, gelb: 0, gruen: 0 };
for (const r of ampel?.rows ?? []) {
  const f = ampelOf(r[1] ?? "");
  if (f) counts[f]++;
}

const blockerMatch = body.match(/##\s*\d+\.\s*Kritische Blocker\s*\n([\s\S]*?)(?=\n##\s)/i);
const blocker = (blockerMatch?.[1] ?? "")
  .split("\n")
  .map((l) => l.match(/^\s*\d+\.\s+(.*)$/)?.[1]?.trim())
  .filter((x): x is string => Boolean(x))
  .slice(0, 3);

// Die vier Dinge, die man hier tun kann – in Alltagssprache.
const aktionen = [
  {
    href: "/assistent",
    icon: "bot",
    label: "Eine Frage stellen",
    desc: "Der Assistent kennt die ganze Projektakte und antwortet sofort – mit Quellenangabe.",
  },
  {
    href: "/hochladen",
    icon: "upload",
    label: "Foto oder Dokument abgeben",
    desc: "Baustellenfotos, Angebote, Pläne – landet automatisch sortiert in der Akte.",
  },
  {
    href: "/medien",
    icon: "image",
    label: "Fotos & Pläne ansehen",
    desc: "Alle Grundrisse, Fotos und PDF-Unterlagen an einem Ort.",
  },
  {
    href: "/checklisten",
    icon: "square-check",
    label: "Checkliste ausfüllen",
    desc: "Maße und Prüfpunkte direkt vor Ort erfassen und speichern.",
  },
];
---

<Base title="Start" current="dashboard">
  <div class="page-head">
    <p class="eyebrow">Ferienhaus Fürstenau · Sanierung</p>
    <h2>Was möchtest du tun?</h2>
    <p class="lead">
      Hier arbeiten Besitzer, Energieberater, Bauleitung und Handwerker mit
      denselben Unterlagen – nichts geht verloren, alles ist nachlesbar.
    </p>
  </div>

  <!-- Hauptaktionen -->
  <div class="start-grid">
    {aktionen.map((a) => (
      <a class="start-tile" href={a.href}>
        <span class="start-ico"><Icon name={a.icon} size={24} /></span>
        <b>{a.label}</b>
        <span class="meta">{a.desc}</span>
        <span class="start-arrow"><Icon name="arrow-right" size={16} /></span>
      </a>
    ))}
  </div>

  <!-- Rollen-Einstieg -->
  <h2 class="section-head">Ich bin …</h2>
  <div class="role-entry-grid">
    {ROLES.map((r) => (
      <a class="role-tile" href={`/fuer/${r.key}`}>
        <span class="role-tile-ico"><Icon name={r.icon} size={20} /></span>
        <b>{r.label}</b>
        <span class="meta">{r.short}</span>
      </a>
    ))}
  </div>

  <!-- Kompakter Projektstand -->
  <h2 class="section-head">Wie steht das Projekt?</h2>
  <div class="card status-teaser">
    <div class="status-teaser-top">
      <span class="muted" style="font-size:13px">Stand {stand ?? "—"}</span>
      <span class="status-counts">
        <span><span class="ampel gruen">✓</span> {counts.gruen} gut</span>
        <span><span class="ampel gelb">!</span> {counts.gelb} in Arbeit</span>
        <span><span class="ampel rot">✕</span> {counts.rot} kritisch</span>
      </span>
    </div>
    {blocker.length > 0 && (
      <div class="status-blocker">
        <b>Wichtigste offene Punkte:</b>
        <ol>
          {blocker.map((b) => <li>{b}</li>)}
        </ol>
      </div>
    )}
    <div class="btn-row">
      <a class="btn primary" href="/status">Zum vollen Projektstand <Icon name="arrow-right" size={15} /></a>
      <a class="btn" href="/kosten">Kosten</a>
      <a class="btn" href="/zeitplan">Zeitplan</a>
    </div>
  </div>
</Base>

<style>
  .start-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; margin-bottom: 8px; }
  .start-tile {
    position: relative; display: flex; flex-direction: column; gap: 6px;
    padding: 20px 18px; border: 1px solid var(--border); border-radius: var(--radius);
    background: var(--panel); color: var(--text);
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }
  .start-tile:hover { border-color: var(--accent); box-shadow: var(--shadow-lg); transform: translateY(-2px); text-decoration: none; }
  .start-ico {
    width: 48px; height: 48px; border-radius: 12px; display: grid; place-items: center;
    background: color-mix(in srgb, var(--accent) 13%, transparent); color: var(--accent); margin-bottom: 6px;
  }
  .start-tile b { color: var(--heading); font-size: 16px; }
  .start-tile .meta { color: var(--muted); font-size: 13px; line-height: 1.5; }
  .start-arrow { position: absolute; top: 20px; right: 16px; color: var(--muted); }
  .start-tile:hover .start-arrow { color: var(--accent); }

  .role-entry-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; }
  .role-tile {
    display: flex; flex-direction: column; gap: 4px; padding: 14px;
    border: 1px solid var(--border); border-radius: var(--radius-sm);
    background: var(--panel); color: var(--text);
    transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  }
  .role-tile:hover { border-color: var(--accent); box-shadow: var(--shadow-lg); transform: translateY(-1px); text-decoration: none; }
  .role-tile-ico { width: 40px; height: 40px; border-radius: 10px; display: grid; place-items: center; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); margin-bottom: 4px; }
  .role-tile b { color: var(--heading); }
  .role-tile .meta { color: var(--muted); font-size: 12.5px; line-height: 1.4; }

  .status-teaser { display: flex; flex-direction: column; gap: 12px; }
  .status-teaser-top { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
  .status-counts { display: flex; gap: 14px; font-size: 13px; font-weight: 600; }
  .status-counts > span { display: inline-flex; align-items: center; gap: 5px; }
  .status-blocker { font-size: 14px; }
  .status-blocker ol { margin: 6px 0 0; padding-left: 20px; display: flex; flex-direction: column; gap: 4px; }
</style>
