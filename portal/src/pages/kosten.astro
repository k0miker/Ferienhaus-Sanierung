---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { KOSTEN_GRUPPEN } from "../content.config";

const positionen = (await getCollection("kosten")).sort(
  (a, b) => b.data.betrag - a.data.betrag,
);

const euro = (n: number) =>
  n.toLocaleString("de-DE", { style: "currency", currency: "EUR", maximumFractionDigits: 0 });

// Summen je Gruppe (AGENTS.md §13) – nur tatsächliche Gruppen (nicht "geschätzt")
const proGruppe = new Map<string, number>();
for (const g of KOSTEN_GRUPPEN) proGruppe.set(g, 0);
for (const p of positionen) proGruppe.set(p.data.gruppe, (proGruppe.get(p.data.gruppe) ?? 0) + p.data.betrag);

const istFoerderung = (g: string) => g.startsWith("Förderung");
const ausgegeben = KOSTEN_GRUPPEN.filter((g) => !istFoerderung(g) && g !== "geschätzt" && g !== "Reserve").reduce(
  (s, g) => s + (proGruppe.get(g) ?? 0),
  0,
);
const foerderungBewilligt = (proGruppe.get("Förderung bewilligt") ?? 0) + (proGruppe.get("Förderung ausgezahlt") ?? 0);
const bezahlt = proGruppe.get("bezahlt") ?? 0;
const beauftragt = proGruppe.get("beauftragt") ?? 0;

// Aktive Gruppen (mit Betrag > 0)
const aktiveGruppen = KOSTEN_GRUPPEN.filter((g) => (proGruppe.get(g) ?? 0) > 0);

const gruppenFarbe: Record<string, string> = {
  geschätzt: "warn",
  "Angebot vorhanden": "info",
  beauftragt: "info",
  bezahlt: "ok",
  Reserve: "warn",
  "Förderung beantragt": "warn",
  "Förderung bewilligt": "ok",
  "Förderung ausgezahlt": "ok",
};
const editBtn = "/admin/index.html#/collections/kosten/new";
---

<Base title="Kosten" current="kosten" crumb="Kosten">
  <div class="page-head">
    <p class="eyebrow">Erfasste Ausgaben</p>
    <h2>Kosten</h2>
    <p class="lead">
      Hier werden nur tatsächlich angefallene Kosten erfasst (Angebote, Aufträge, Zahlungen).
      Grobschätzungen und Prognosen stehen in der Kostenrechnung.
    </p>
    <div class="btn-row">
      <a class="btn primary" href={editBtn}>+ Kostenposition erfassen</a>
      <a class="btn" href="/docs/06_kosten/kostenrechnung-prognose">Kostenprognose (Schätzungen)</a>
      <a class="btn" href="/docs/06_kosten/kostenplan">Kostenplan</a>
    </div>
  </div>

  <!-- Kennzahlen -->
  <div class="grid cols-4" style="margin-bottom:22px">
    <div class="card stat"><span class="label">Ausgegeben</span><span class="value">{euro(ausgegeben)}</span></div>
    <div class="card stat"><span class="label">Davon bezahlt</span><span class="value">{euro(bezahlt)}</span></div>
    <div class="card stat"><span class="label">Förderung bewilligt</span><span class="value">{euro(foerderungBewilligt)}</span></div>
    <div class="card stat"><span class="label">Positionen</span><span class="value">{positionen.length}</span></div>
  </div>

  {aktiveGruppen.length > 1 && (
    <h3 style="margin:8px 0 12px">Summen je Gruppe</h3>
    <div class="grid cols-4" style="margin-bottom:24px">
      {
        aktiveGruppen.map((g) => (
          <div class="card stat">
            <span class="label">
              <span class={`badge ${gruppenFarbe[g] ?? "info"}`}>{g}</span>
            </span>
            <span class="value" style="font-size:18px">{euro(proGruppe.get(g) ?? 0)}</span>
          </div>
        ))
      }
    </div>
  )}

  <!-- Positionen -->
  <h3 style="margin:8px 0 12px">Erfasste Positionen</h3>
  <div class="card" style="padding:0; overflow:hidden">
    {
      positionen.length ? (
        <table class="prose" style="margin:0; width:100%">
          <thead>
            <tr><th>Titel</th><th>Bereich</th><th>Gruppe</th><th style="text-align:right">Betrag</th><th>Datum</th></tr>
          </thead>
          <tbody>
            {positionen.map((p) => (
              <tr>
                <td><b>{p.data.titel}</b>{p.data.notiz && <div class="muted" style="font-size:12px">{p.data.notiz}</div>}</td>
                <td>{p.data.bereich}</td>
                <td><span class={`badge ${gruppenFarbe[p.data.gruppe] ?? "info"}`}>{p.data.gruppe}</span></td>
                <td style="text-align:right; white-space:nowrap">
                  {euro(p.data.betrag)}<br /><span class="muted" style="font-size:11px">{p.data.brutto ? "brutto" : "netto"}</span>
                </td>
                <td class="muted" style="font-size:13px; white-space:nowrap">{p.data.datum ? new Date(p.data.datum).toLocaleDateString("de-DE") : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="empty">
          Noch keine Kostenpositionen erfasst. Lege die erste über „+ Kostenposition erfassen" an.
        </p>
      )
    }
  </div>

  <!-- Hinweis auf Prognose -->
  <div class="card" style="margin-top:20px; border-color:var(--accent)">
    <h3>Grobschätzung / Prognose</h3>
    <p style="margin:6px 0; font-size:14px">
      Die vorläufige Gesamtschätzung für alle Sanierungsmaßnahmen liegt bei
      <b>ca. 50.000–86.000 €</b> (Split-Variante) bzw. <b>60.000–112.000 €</b> (WP+FBH).
      Details und Varianten:
    </p>
    <div class="btn-row">
      <a class="btn" href="/docs/06_kosten/kostenrechnung-prognose">Kostenrechnung-Prognose öffnen</a>
    </div>
  </div>

  <p class="muted" style="font-size:13px; margin-top:16px">
    Positionen liegen als Markdown in <code>06_kosten/positionen/</code> und werden hier automatisch ausgewertet.
    Weitere Dokumente:
    <a href="/docs/06_kosten/zahlungen">Zahlungen</a> ·
    <a href="/docs/06_kosten/eigenleistung">Eigenleistung</a> ·
    <a href="/docs/06_kosten/reserve">Reserve</a>
  </p>
</Base>
