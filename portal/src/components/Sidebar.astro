---
import { getCollection } from "astro:content";
import { SECTIONS, sectionFor } from "../lib/sections";
import { ROLES } from "../lib/roles";
import Icon from "./Icon.astro";

const { current } = Astro.props as { current?: string };

const docs = await getCollection("docs");
const counts = new Map<string, number>();
for (const d of docs) {
  const key = sectionFor(d.id).key;
  counts.set(key, (counts.get(key) ?? 0) + 1);
}

const topLinks = [{ href: "/", label: "Start", icon: "home", id: "dashboard" }];

// Gruppen in Alltagssprache – zuerst das, was man TUT, dann das, was man LIEST.
const machen = [
  { href: "/assistent", label: "Fragen stellen", icon: "bot", id: "assistent" },
  { href: "/hochladen", label: "Hochladen", icon: "upload", id: "hochladen" },
  { href: "/checklisten", label: "Checklisten", icon: "square-check", id: "checklisten" },
];
const nachschlagen = [
  { href: "/status", label: "Projektstand", icon: "clipboard-list", id: "status" },
  { href: "/medien", label: "Fotos & Pläne", icon: "image", id: "medien" },
  { href: "/kosten", label: "Kosten", icon: "euro", id: "kosten" },
  { href: "/zeitplan", label: "Zeitplan", icon: "calendar", id: "zeitplan" },
  { href: "/aufgaben", label: "Aufgaben & Fragen", icon: "list-checks", id: "aufgaben" },
  { href: "/kontakte", label: "Kontakte", icon: "contact", id: "kontakte" },
];

const bereiche = SECTIONS.filter((s) => s.key !== "_root" && (counts.get(s.key) ?? 0) > 0).sort(
  (a, b) => a.order - b.order,
);
---

<aside class="sidebar" id="sidebar">
  <a class="brand" href="/">
    <span class="logo"><Icon name="home" size={20} /></span>
    <div>
      <h1>Ferienhaus Fürstenau</h1>
      <small>Sanierungszentrale</small>
    </div>
  </a>

  <div class="searchbox">
    <input type="search" id="quicksearch" placeholder="Schnellsuche…" autocomplete="off" />
  </div>

  <nav class="nav" aria-label="Hauptnavigation">
    {
      topLinks.map((l) => (
        <a href={l.href} class={current === l.id ? "active" : ""}>
          <span class="ico"><Icon name={l.icon} /></span>
          <span>{l.label}</span>
        </a>
      ))
    }

    <div class="group-label">Mitmachen</div>
    {
      machen.map((l) => (
        <a href={l.href} class={current === l.id ? "active" : ""}>
          <span class="ico"><Icon name={l.icon} /></span>
          <span>{l.label}</span>
        </a>
      ))
    }

    <div class="group-label">Nachschlagen</div>
    {
      nachschlagen.map((l) => (
        <a href={l.href} class={current === l.id ? "active" : ""}>
          <span class="ico"><Icon name={l.icon} /></span>
          <span>{l.label}</span>
        </a>
      ))
    }

    <div class="group-label">Für dich</div>
    {
      ROLES.map((r) => (
        <a href={`/fuer/${r.key}`} class={current === `rolle-${r.key}` ? "active" : ""}>
          <span class="ico"><Icon name={r.icon} /></span>
          <span>{r.label}</span>
        </a>
      ))
    }

    <div class="group-label">Themen im Detail</div>
    {
      bereiche.map((s) => (
        <a href={`/bereich/${s.key}`} class={current === s.key ? "active" : ""}>
          <span class="ico"><Icon name={s.icon} /></span>
          <span>{s.label}</span>
          <span class="count">{counts.get(s.key)}</span>
        </a>
      ))
    }

    <div class="group-label">Verwaltung</div>
    <a href="/admin/index.html" class={current === "cms" ? "active" : ""}>
      <span class="ico"><Icon name="pencil" /></span>
      <span>Inhalte pflegen (CMS)</span>
    </a>
  </nav>
</aside>

<script>
  const input = document.getElementById("quicksearch") as HTMLInputElement | null;
  input?.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && input.value.trim()) {
      window.location.href = "/suche?q=" + encodeURIComponent(input.value.trim());
    }
  });
</script>
