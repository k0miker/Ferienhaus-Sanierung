---
/**
 * Globale Befehls-/Sprungpalette (⌘K bzw. Strg+K). Durchsucht Seiten, Rollen,
 * Bereiche und – lazy aus /search-index.json – alle Dokumente. Reine Navigation,
 * kein Backend. Wird in Base.astro eingebunden.
 */
import Icon from "./Icon.astro";
import { SECTIONS } from "../lib/sections";
import { ROLES } from "../lib/roles";

const nav = [
  { url: "/", title: "Dashboard", section: "Seite", icon: "layout-dashboard" },
  { url: "/zeitplan", title: "Zeitplan", section: "Seite", icon: "calendar-days" },
  { url: "/kosten", title: "Kosten", section: "Seite", icon: "euro" },
  { url: "/checklisten", title: "Checklisten", section: "Seite", icon: "square-check" },
  { url: "/aufgaben", title: "Aufgaben & Fragen", section: "Seite", icon: "list-checks" },
  { url: "/kontakte", title: "Kontakte", section: "Seite", icon: "contact" },
  { url: "/medien", title: "Pläne & Medien", section: "Seite", icon: "image" },
  { url: "/hochladen", title: "Hochladen", section: "Seite", icon: "upload" },
  { url: "/suche", title: "Suche", section: "Seite", icon: "search" },
  ...ROLES.map((r) => ({ url: `/fuer/${r.key}`, title: `Für ${r.label}`, section: "Rolle", icon: r.icon })),
  ...SECTIONS.filter((s) => s.key !== "_root").map((s) => ({
    url: `/bereich/${s.key}`,
    title: s.label,
    section: "Bereich",
    icon: s.icon,
  })),
];
---

<div class="cmdk" id="cmdk" hidden>
  <button type="button" class="cmdk-backdrop" id="cmdk-backdrop" aria-label="Schließen" tabindex="-1"></button>
  <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Schnellsuche">
    <div class="cmdk-input-row">
      <Icon name="search" size={17} />
      <input
        type="text"
        id="cmdk-input"
        placeholder="Seiten, Rollen, Dokumente … springen mit ↵"
        autocomplete="off"
        spellcheck="false"
      />
      <kbd class="cmdk-esc">Esc</kbd>
    </div>
    <ul class="cmdk-list" id="cmdk-list" role="listbox"></ul>
    <div class="cmdk-foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> wählen</span>
      <span><kbd><Icon name="corner-down-left" size={11} /></kbd> öffnen</span>
      <span><kbd>⌘</kbd><kbd>K</kbd> öffnen/schließen</span>
    </div>
  </div>
</div>

<script type="application/json" id="cmdk-nav" set:html={JSON.stringify(nav)} />

<script>
  type Item = { url: string; title: string; section: string; icon?: string; excerpt?: string };
  const root = document.getElementById("cmdk")!;
  const input = document.getElementById("cmdk-input") as HTMLInputElement;
  const list = document.getElementById("cmdk-list")!;
  const nav: Item[] = JSON.parse(document.getElementById("cmdk-nav")!.textContent || "[]");

  let docs: Item[] = [];
  let docsLoaded = false;
  let active = 0;
  let results: Item[] = [];

  async function ensureDocs() {
    if (docsLoaded) return;
    docsLoaded = true;
    try {
      const res = await fetch("/search-index.json");
      const raw = (await res.json()) as Array<{ url: string; title: string; section: string; icon?: string; excerpt?: string }>;
      docs = raw.map((d) => ({ ...d, section: d.section || "Dokument" }));
    } catch {}
  }

  function score(item: Item, q: string): number {
    const t = item.title.toLowerCase();
    if (!q) return 1;
    if (t === q) return 100;
    if (t.startsWith(q)) return 80;
    if (t.includes(q)) return 60;
    if (item.excerpt?.toLowerCase().includes(q)) return 20;
    // einfache Fuzzy: alle Buchstaben in Reihenfolge
    let i = 0;
    for (const ch of t) if (ch === q[i]) i++;
    return i === q.length ? 10 : 0;
  }

  function render() {
    const q = input.value.trim().toLowerCase();
    const pool = q ? [...nav, ...docs] : nav;
    results = pool
      .map((it) => ({ it, s: score(it, q) }))
      .filter((x) => x.s > 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, 40)
      .map((x) => x.it);
    active = 0;
    list.innerHTML = results
      .map(
        (r, i) => `
      <li role="option" class="cmdk-item${i === active ? " active" : ""}" data-i="${i}" data-url="${r.url}">
        <span class="cmdk-sec">${r.section}</span>
        <span class="cmdk-title">${escapeHtml(r.title)}</span>
      </li>`,
      )
      .join("");
    if (!results.length) list.innerHTML = `<li class="cmdk-empty">Nichts gefunden für „${escapeHtml(q)}"</li>`;
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);
  }

  function move(delta: number) {
    if (!results.length) return;
    active = (active + delta + results.length) % results.length;
    [...list.children].forEach((el, i) => el.classList.toggle("active", i === active));
    list.children[active]?.scrollIntoView({ block: "nearest" });
  }

  function go() {
    const r = results[active];
    if (r) window.location.href = r.url;
  }

  async function open() {
    root.hidden = false;
    document.body.style.overflow = "hidden";
    await ensureDocs();
    input.value = "";
    render();
    input.focus();
  }
  function close() {
    root.hidden = true;
    document.body.style.overflow = "";
  }

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      root.hidden ? open() : close();
    } else if (!root.hidden) {
      if (e.key === "Escape") close();
      else if (e.key === "ArrowDown") { e.preventDefault(); move(1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); move(-1); }
      else if (e.key === "Enter") { e.preventDefault(); go(); }
    }
  });
  input.addEventListener("input", render);
  document.getElementById("cmdk-backdrop")?.addEventListener("click", close);
  list.addEventListener("click", (e) => {
    const li = (e.target as HTMLElement).closest<HTMLElement>(".cmdk-item");
    if (li) window.location.href = li.dataset.url!;
  });
  // Trigger-Buttons (z.B. Topbar) können data-cmdk-open tragen
  document.querySelectorAll("[data-cmdk-open]").forEach((b) => b.addEventListener("click", open));
</script>

<style>
  .cmdk { position: fixed; inset: 0; z-index: 50; display: flex; justify-content: center; align-items: flex-start; }
  .cmdk[hidden] { display: none; } /* sonst überschreibt display:flex das hidden-Attribut */
  .cmdk-backdrop { position: absolute; inset: 0; border: 0; background: rgba(15, 23, 42, 0.5); backdrop-filter: blur(2px); }
  .cmdk-panel {
    position: relative; margin-top: 12vh; width: min(620px, 92vw);
    background: var(--panel); border: 1px solid var(--border-strong);
    border-radius: var(--radius); box-shadow: var(--shadow-lg); overflow: hidden;
  }
  .cmdk-input-row { display: flex; align-items: center; gap: 10px; padding: 14px 16px; border-bottom: 1px solid var(--border); color: var(--muted); }
  .cmdk-input-row input { flex: 1; border: 0; background: transparent; color: var(--text); font: inherit; font-size: 16px; outline: none; }
  .cmdk-esc { font-size: 11px; color: var(--muted); border: 1px solid var(--border); border-radius: 5px; padding: 1px 6px; }
  .cmdk-list { list-style: none; margin: 0; padding: 6px; max-height: 52vh; overflow-y: auto; }
  .cmdk-item { display: flex; align-items: center; gap: 12px; padding: 9px 12px; border-radius: var(--radius-sm); cursor: pointer; }
  .cmdk-item.active { background: color-mix(in srgb, var(--accent) 14%, transparent); }
  .cmdk-sec { font-size: 10.5px; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); background: var(--panel-2); padding: 2px 7px; border-radius: 20px; flex: none; min-width: 64px; text-align: center; }
  .cmdk-title { color: var(--text); font-size: 14.5px; }
  .cmdk-item.active .cmdk-title { color: var(--accent); font-weight: 600; }
  .cmdk-empty { padding: 18px 12px; color: var(--muted); font-style: italic; }
  .cmdk-foot { display: flex; gap: 16px; padding: 8px 14px; border-top: 1px solid var(--border); font-size: 11.5px; color: var(--muted); }
  .cmdk-foot kbd { border: 1px solid var(--border); border-radius: 4px; padding: 0 5px; margin: 0 1px; font-family: var(--mono); display: inline-flex; align-items: center; }
  @media (max-width: 860px) { .cmdk-foot { display: none; } }
</style>
