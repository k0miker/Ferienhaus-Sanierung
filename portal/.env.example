# Vorlage für die Umgebungsvariablen. Kopieren nach `.env` und Werte einsetzen:
#   cp .env.example .env
# In Produktion dieselben Werte in der Netlify-UI hinterlegen.

# --- Zugangsschutz (Basic-Auth) ---
PORTAL_USER=
PORTAL_PASSWORD=
# Optional mehrere Logins, Format user:pass per Komma:
PORTAL_USERS=

# --- Checkliste „In Akte speichern" ---
PORTAL_WRITE_KEY=
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# --- Sonstiges ---
SITE_URL=
