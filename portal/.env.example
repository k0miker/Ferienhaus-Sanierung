# Vorlage für die Umgebungsvariablen. Kopieren nach `.env` und Werte einsetzen:
#   cp .env.example .env
# In Produktion dieselben Werte in der Netlify-UI hinterlegen.

# --- Zugangsschutz (Basic-Auth) ---
PORTAL_USER=
PORTAL_PASSWORD=
# Optional mehrere Logins, Format user:pass per Komma:
PORTAL_USERS=

# --- Schreiben in die Akte (Checklisten „In Akte speichern" + /hochladen) ---
PORTAL_WRITE_KEY=
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# --- KI-Assistent (/assistent) ---
# API-Key von https://platform.claude.com (alternativ: ANTHROPIC_API_KEY)
CLAUDE_API_KEY=
# Optionales Modell-Override, Default: claude-opus-4-8
CHAT_MODEL=

# --- Sonstiges ---
SITE_URL=
